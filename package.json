{
  "name": "gifts-in-service",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Privacy-minded volunteer skills discovery for churches",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@11.13.1",
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green 'pnpm --filter @gis/public-api dev' 'pnpm --filter @gis/web dev'",
    "build": "pnpm -r --if-present build",
    "build:lambdas": "tsx scripts/package-lambdas.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "pnpm -r --if-present typecheck && tsc -p tsconfig.tests.json --noEmit",
    "test": "vitest run --project unit",
    "test:integration": "bash -c 'set -a; source .env.example; set +a; pnpm db:migrate && pnpm db:seed && vitest run --project integration'",
    "test:e2e": "playwright test",
    "test:a11y": "playwright test tests/e2e/accessibility.spec.ts",
    "eval:ai": "vitest run --project ai-eval",
    "db:migrate": "tsx services/migration-runner/src/cli.ts migrate",
    "db:seed": "tsx services/migration-runner/src/cli.ts seed",
    "infra:fmt": "terraform fmt -check -recursive infra",
    "infra:validate": "bash scripts/terraform-validate.sh",
    "preflight": "tsx scripts/preflight.ts",
    "audit:repo": "bash scripts/repository-safety-scan.sh",
    "audit:dependencies": "pnpm audit --prod --audit-level high"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@types/node": "26.1.1",
    "@typescript-eslint/eslint-plugin": "8.64.0",
    "@typescript-eslint/parser": "8.64.0",
    "concurrently": "10.0.3",
    "esbuild": "0.28.1",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "prettier": "3.9.5",
    "tsx": "4.23.1",
    "typescript": "7.0.2",
    "typescript-eslint": "8.64.0",
    "vitest": "4.1.10"
  }
}
